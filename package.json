{
  "name": "@agenticbridge/style-trace",
  "version": "0.5.2",
  "description": "Playwright-based MCP server that extracts evidence-first website style signals.",
  "type": "module",
  "files": [
    "dist/src/",
    "README.md"
  ],
  "bin": {
    "style-trace": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx test/*.test.ts",
    "test:mcp-cli": "bash scripts/test-mcp-cli.sh",
    "test:e2e": "tsx test/e2e/runReview.ts",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "main": "dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js",
    "./package.json": "./package.json"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgenticBridge/style-trace.git"
  },
  "keywords": [
    "mcp",
    "node",
    "website",
    "reverse-engineering",
    "style",
    "agent",
    "web"
  ],
  "author": "agentic-bridge",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AgenticBridge/style-trace/issues"
  },
  "homepage": "https://github.com/AgenticBridge/style-trace#readme"
}
